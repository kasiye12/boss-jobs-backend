# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=boss_jobs_ethiopia
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_MAX_POOL=20
DB_MIN_POOL=2
DB_IDLE_TIMEOUT=30000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=your_bot_username

# Cloud Storage (AWS S3 or DigitalOcean Spaces)
STORAGE_PROVIDER=digitalocean
DO_SPACES_KEY=your_digitalocean_spaces_key
DO_SPACES_SECRET=your_digitalocean_spaces_secret
DO_SPACES_ENDPOINT=ams3.digitaloceanspaces.com
DO_SPACES_BUCKET=boss-jobs-uploads
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=boss-jobs-uploads

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Application Configuration
MAX_AUDIO_SIZE_MB=5
MAX_AUDIO_DURATION_SECONDS=30
MAX_PROFILE_IMAGE_SIZE_MB=2
GEOCODING_API_KEY=your_google_maps_api_key
DEFAULT_SEARCH_RADIUS_KM=10
MAX_SEARCH_RADIUS_KM=50
